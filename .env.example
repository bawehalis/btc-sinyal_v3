# ============================================================
#  .env.example
#  Gercek .env dosyasini buradan olustur:
#  cp .env.example .env
# ============================================================

TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# FRED API (M2 para arzi icin - ucretsiz)
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Whale Alert (opsiyonel - ucretsiz plan yeterli)
# https://whale-alert.io/
WHALE_ALERT_KEY=

# Glassnode (opsiyonel - ucretli, gercek MVRV icin)
GLASSNODE_KEY=
